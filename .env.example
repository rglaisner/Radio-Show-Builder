# .env.example
# Copy to .env.local and fill in values (see README.md)

# Required for show generation (Gemini Managed Agents / Interactions API)
GEMINI_API_KEY=

# Google Cloud Storage bucket name for private share URLs
GCS_BUCKET_NAME=

# Daily show generation limit (default is 3)
DAILY_QUOTA_LIMIT=

NODE_ENV=development

# Set to true/false to force Google sign-in in production builds.
# When unset, auth is auto-enabled only after firebase-applet-config.json is configured.
# VITE_REQUIRE_GOOGLE_AUTH=
